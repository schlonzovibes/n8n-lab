        "jsCode": "try {\n  const raw = $json.message.content\n    .replace(/```json\\n?/g, '')\n    .replace(/```/g, '')\n    .trim();\n  return [{ json: { result: JSON.parse(raw), success: true }}];\n} catch(e) {\n  return [{ json: { result: null, success: false, rawOutput: $json.message.content }}];\n}"
