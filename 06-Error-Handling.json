    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst stats = {};\n\nfor (const item of items) {\n  const category = (item.json.result.category || 'unknown').toLowerCase();\n  const urgency = (item.json.result.urgency || 'unknown').toLowerCase();\n\n  if (!stats[category]) {\n    stats[category] = {\n      total: 0,\n      high: 0,\n      medium: 0,\n      low: 0\n    };\n  }\n\n  stats[category].total++;\n\n  if (urgency === 'high') stats[category].high++;\n  if (urgency === 'medium') stats[category].medium++;\n  if (urgency === 'low') stats[category].low++;\n}\n\nreturn [\n  {\n    json: stats\n  }\n];"
      },
